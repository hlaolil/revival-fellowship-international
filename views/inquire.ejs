<%- include('partials/header', { activePage: 'join' }) %>

<section class="hero relative h-96 bg-cover bg-center" style="background-image: url('/images/heroo.webp')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <h1 class="text-5xl md:text-7xl font-bold text-white font-heading">Enquiry Form</h1>
  </div>
</section>

<div class="max-w-2xl mx-auto px-6 py-16">
  <form method="POST" action="/inquire" class="bg-white p-10 rounded-2xl shadow-2xl">
    <div class="grid md:grid-cols-2 gap-8">
      <div class="mb-6">
        <label class="block text-lg font-bold mb-2">First Name <span class="text-red-500">*</span></label>
        <input type="text" name="first-name" required placeholder="John" class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
      </div>
      <div class="mb-6">
        <label class="block text-lg font-bold mb-2">Last Name <span class="text-red-500">*</span></label>
        <input type="text" name="last-name" required placeholder="Doe" class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent">
      </div>
    </div>

    <div class="mb-6">
      <label class="block text-lg font-bold mb-2">Email <span class="text-red-500">*</span></label>
      <input type="email" name="email" required placeholder="you@example.com" class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent">
    </div>

    <div class="mb-6">
      <label class="block text-lg font-bold mb-2">Mobile Phone <span class="text-red-500">*</span></label>
      <input type="tel" name="phone" required placeholder="+266 62233969" class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent">
    </div>

    <div class="mb-6">
      <label class="block text-lg font-bold mb-2">Enquiry Type <span class="text-red-500">*</span></label>
      <select name="enquiry-type" required class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent">
        <option value="">Select an option</option>
        <option value="prayer-request">Prayer Request</option>
        <option value="appointment-request">Appointment Request</option>
        <option value="membership-request">Membership Request</option>
      </select>
    </div>

    <div class="mb-8">
      <label class="block text-lg font-bold mb-2">Message</label>
      <textarea name="message" rows="6" placeholder="Tell us how we can help you..." class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:border-transparent"></textarea>
    </div>

    <input type="hidden" name="timestamp" id="timestamp">

    <div class="text-center">
      <button type="submit" class="bg-primary hover:bg-accent text-white font-bold py-4 px-12 rounded-full text-xl shadow-lg hover:shadow-xl transition">Submit Enquiry</button>
    </div>
  </form>
</div>

<script>
  document.getElementById('timestamp').value = new Date().toLocaleString();
</script>

<%- include('partials/footer') %>
