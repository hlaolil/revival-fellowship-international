<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="author" content="Letlotlo Hlaoli">
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Revival Fellowship International – An assembly of faithful stewards of the manifold grace of God. Based in Butha-Buthe, Lesotho.' %>">
  <meta name="keywords" content="Revival Fellowship International, RFI, church, Lesotho, Butha-Buthe, ministry, worship, discipleship">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Revival Fellowship International">
  <meta property="og:title" content="<%= title %> - Revival Fellowship International">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'An assembly of faithful stewards of the manifold grace of God.' %>">
  <meta property="og:image" content="/images/hero.webp">
  <meta property="og:locale" content="en_LS">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %> - Revival Fellowship International">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'An assembly of faithful stewards of the manifold grace of God.' %>">
  <meta name="twitter:image" content="/images/hero.webp">

  <title><%= title %> - Revival Fellowship International</title>

  <!-- Tailwind CDN + Custom Colors -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#008080',
            secondary: '#FFA500',
            accent: '#006d77',
          },
          fontFamily: {
            heading: ['Georgia', 'serif'],
            body: ['system-ui', 'sans-serif']
          }
        }
      }
    }
  </script>

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="icon" href="/images/fav.jpg" type="image/x-icon">

  <style>
    @keyframes heroFadeIn {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .hero-title   { animation: heroFadeIn 0.9s ease forwards; }
    .hero-tagline { opacity: 0; animation: heroFadeIn 0.9s ease 0.35s forwards; }
    .hero-cta     { opacity: 0; animation: heroFadeIn 0.9s ease 0.65s forwards; }

    /* Dropdown */
    .nav-dropdown:hover .dropdown-menu,
    .nav-dropdown:focus-within .dropdown-menu { display: block; }
    .dropdown-menu { display: none; }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">

<header class="bg-primary text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
    <div class="flex items-center space-x-4">
      <a href="/"><img src="/images/logo.webp" alt="RFI Logo" class="h-20 w-auto rounded-lg sm:h-24 lg:h-28"></a>
      <a href="/" class="hover:text-secondary transition">
        <h1 class="text-2xl font-bold hidden sm:block">Revival Fellowship International</h1>
      </a>
    </div>

    <!-- Hamburger -->
    <button id="menu-btn" class="lg:hidden text-white focus:outline-none" aria-label="Toggle menu">
      <i class="fas fa-bars text-3xl"></i>
    </button>

    <!-- Desktop Navigation -->
    <nav id="nav-menu" class="hidden lg:flex items-center space-x-1">
      <a href="/" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'home' ? 'bg-secondary font-bold' : '' %>">Home</a>
      <a href="/about" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'about' ? 'bg-secondary font-bold' : '' %>">About</a>
      <a href="/ministries" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'ministries' ? 'bg-secondary font-bold' : '' %>">Ministries</a>
      <a href="/sermons" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'sermons' ? 'bg-secondary font-bold' : '' %>">Sermons</a>
      <a href="/news" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'news' ? 'bg-secondary font-bold' : '' %>">News</a>
      <a href="/gallery" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'gallery' ? 'bg-secondary font-bold' : '' %>">Gallery</a>
      <a href="/join" class="px-4 py-3 rounded-md hover:bg-secondary transition <%= activePage === 'join' ? 'bg-secondary font-bold' : '' %>">Get Involved</a>
      <!-- WhatsApp CTA -->
      <a href="https://wa.me/26662233969" target="_blank" rel="noopener"
         class="ml-2 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-full flex items-center gap-2 transition font-semibold text-sm">
        <i class="fab fa-whatsapp text-lg"></i><span>WhatsApp</span>
      </a>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-primary border-t border-teal-700">
    <a href="/" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'home' ? 'bg-secondary font-bold' : '' %>">Home</a>
    <a href="/about" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'about' ? 'bg-secondary font-bold' : '' %>">About Us</a>
    <a href="/ministries" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'ministries' ? 'bg-secondary font-bold' : '' %>">Ministries</a>
    <a href="/sermons" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'sermons' ? 'bg-secondary font-bold' : '' %>">Sermons</a>
    <a href="/news" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'news' ? 'bg-secondary font-bold' : '' %>">News</a>
    <a href="/gallery" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'gallery' ? 'bg-secondary font-bold' : '' %>">Gallery</a>
    <a href="/join" class="block px-6 py-4 hover:bg-secondary <%= activePage === 'join' ? 'bg-secondary font-bold' : '' %>">Get Involved</a>
    <a href="https://wa.me/26662233969" target="_blank" rel="noopener"
       class="block px-6 py-4 bg-green-600 hover:bg-green-700 font-semibold">
      <i class="fab fa-whatsapp mr-2"></i>WhatsApp Us
    </a>
  </div>
</header>

<script>
  document.getElementById('menu-btn').addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
