<%- include('partials/header', { activePage: 'home' }) %>

<!-- Hero -->
<section class="relative h-96 md:h-screen max-h-screen overflow-hidden">
  <img src="/images/hero.webp" alt="Worship" class="w-full h-full object-cover hidden md:block">
  <img src="/images/hero1.webp" alt="Worship" class="w-full h-full object-cover md:hidden">
  
  <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center">
    <div class="text-center text-white px-6">
      <h1 class="text-4xl md:text-6xl font-bold font-heading mb-6">Revival Fellowship International</h1>
      <a href="/join" class="inline-block bg-primary hover:bg-accent text-white font-bold py-4 px-10 rounded-full text-xl shadow-lg transform hover:scale-105 transition">Get Involved</a>
    </div>
  </div>
</section>

<main class="max-w-7xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-10">
  <div class="bg-white p-8 rounded-xl rounded-xl shadow-lg">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">Upcoming Events</h2>
    <ul class="space-y-3">
      <% upcomingEvents.forEach(event => { %>
        <li class="border-b pb-2"><strong><%= event.name %></strong><br><em><%= event.date %></em></li>
      <% }) %>
    </ul>
  </div>

  <div class="bg-white p-8 rounded-xl shadow-lg">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">Contact Us</h2>
    <p class="text-left leading-relaxed">
      A1 Road, Opposite Usave<br>
      Behind BEDCO, Butha-Buthe 400<br>
      Lesotho<br><br>
      Email: tlokza@gmail.com<br>
      Phone: +266 62233969
    </p>
  </div>

  <div class="bg-white p-8 rounded-xl shadow-lg">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">Location</h2>
    <iframe src="https://www.google.com/maps/embed/v1/place?q=-28.768911662039518,28.248175690554746&z=17&key=AIzaSyDmpS1s3gjr-2KZVZr1lF4-8bXz0E1X0cE"
      class="w-full h-64 rounded-lg border-0" allowfullscreen="" loading="lazy"></iframe>
  </div>
</main>

<!-- Spotlight Services -->
<section class="bg-gray-100 py-16">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-3xl font-bold text-center mb-12">Our Services</h2>
    <div class="grid md:grid-cols-3 gap-10">
      <% routineServices.forEach(service => { %>
        <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transition transform hover:-translate-y-2">
          <% if (service.videoLink) { %>
            <iframe class="w-full h-64" src="<%= service.videoLink %>" allowfullscreen></iframe>
          <% } else { %>
            <img src="/images/<%= service.image %>" alt="<%= service.name %>" class="w-full h-64 object-cover">
          <% } %>
          <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-primary"><%= service.name %></h3>
            <p class="mt-4"><strong>Schedule:</strong> <%= service.schedule %></p>
            <p><strong>Contact:</strong> <%= service.contact %></p>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
