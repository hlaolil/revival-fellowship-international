<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Revival Fellowship International</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="/css/style.css" rel="stylesheet" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
  <style>
    .font-heading { font-family: 'Playfair Display', serif; }
    .animate-marquee {
      animation: marquee 20s linear infinite;
    }
    @keyframes marquee {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>
</head>
<body class="flex flex-col min-h-screen bg-gray-50">

  <%- include('partials/header', { activePage: 'home', title: 'Home' }) %>

  <!-- HERO SECTION – With responsive top padding to separate from header -->
  <section class="relative h-96 md:h-screen max-h-screen overflow-hidden pt-16 md:pt-0">
    <img src="/images/hero.webp" alt="Worship" class="w-full h-full object-cover hidden md:block">
    <img src="/images/hero1.webp" alt="Worship" class="w-full h-full object-cover md:hidden">

    <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <!-- Animated Moving Title -->
        <div class="overflow-hidden">
          <h1 class="inline-block text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-heading mb-8 animate-marquee whitespace-nowrap">
            Revival Fellowship International
            <!-- Duplicated for seamless loop -->
            <span class="ml-16 opacity-0">Revival Fellowship International</span>
            <span class="ml-16">Revival Fellowship International</span>
          </h1>
        </div>
        <a href="/join" class="inline-block bg-white text-primary hover:bg-secondary font-bold py-4 px-12 rounded-full text-xl shadow-2xl transform hover:scale-105 transition duration-300">
          Get Involved
        </a>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT – Three Cards -->
  <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 grid md:grid-cols-3 gap-10">
    <!-- Upcoming Events -->
    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
      <h2 class="text-2xl font-bold text-primary mb-4 text-center">Upcoming Events</h2>
      <ul class="space-y-3 text-gray-700">
        <% if (upcomingEvents && upcomingEvents.length > 0) { %>
          <% upcomingEvents.forEach(event => { %>
            <li class="border-b pb-2">
              <strong><%= event.name %></strong><br>
              <em class="text-sm"><%= event.date %></em>
            </li>
          <% }) %>
        <% } else { %>
          <li class="text-center text-gray-500">No upcoming events</li>
        <% } %>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
      <h2 class="text-2xl font-bold text-primary mb-4 text-center">Contact Us</h2>
      <p class="text-left leading-relaxed text-gray-700">
        A1 Road, Opposite Usave<br>
        Behind BEDCO, Butha-Buthe 400<br>
        Lesotho<br><br>
        <strong>Email:</strong> tlokza@gmail.com<br>
        <strong>Phone:</strong> +266 62233969
      </p>
    </div>

    <!-- Location Map -->
    <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
      <h2 class="text-2xl font-bold text-primary mb-4 text-center">Our Location</h2>
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1485.56110514829!2d28.2472789!3d-28.7689499!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNjZKWCtDNzksIEJ1dGhhLUJ1dGhl!5e0!3m2!1sen!2sls!4v1739637032866!5m2!1sen!2sls"
        class="w-full h-64 rounded-lg border-0"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </div>
  </main>

  <!-- OUR SERVICES SECTION -->
  <section class="bg-gray-100 py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-primary">Our Services</h2>
      <div class="grid md:grid-cols-3 gap-10">
        <% routineServices.forEach(service => { %>
          <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transform hover:-translate-y-3 transition duration-300">
            <% if (service.videoLink) { %>
              <iframe class="w-full h-64" src="<%= service.videoLink %>" title="<%= service.name %>" allowfullscreen></iframe>
            <% } else { %>
              <img src="/images/<%= service.image %>" alt="<%= service.name %>" class="w-full h-64 object-cover">
            <% } %>
            <div class="p-6 text-center">
              <h3 class="text-xl font-bold text-primary mb-3"><%= service.name %></h3>
              <p class="text-gray-700"><strong>Schedule:</strong> <%= service.schedule %></p>
              <p class="text-gray-700 mt-2"><strong>Contact:</strong> <%= service.contact %></p>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
