<%- include('partials/header', { activePage: 'home', title: 'Home' }) %>

<!-- HERO SECTION -->
<section class="relative h-96 md:h-screen max-h-screen overflow-hidden">
  <img src="/images/hero.webp" alt="Worship" class="w-full h-full object-cover hidden md:block">
  <img src="/images/hero1.webp" alt="Worship" class="w-full h-full object-cover md:hidden">
  <div class="absolute inset-0 bg-black bg-opacity-50 flex items-center justify-center">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-heading mb-4 hero-title">
        Revival Fellowship International
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl mb-10 text-gray-200 hero-tagline">
        An assembly of faithful stewards of the manifold grace of God
      </p>
      <a href="/join" class="inline-block bg-white text-primary hover:bg-secondary hover:text-white font-bold py-4 px-12 rounded-full text-xl shadow-2xl transform hover:scale-105 transition duration-300 hero-cta">
        Get Involved
      </a>
    </div>
  </div>
</section>

<!-- MAIN CONTENT – Three Cards -->
<main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid md:grid-cols-3 gap-10">
  <!-- Upcoming Events -->
  <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">
      <i class="fas fa-calendar-alt mr-2"></i>Upcoming Events
    </h2>
    <ul class="space-y-3 text-gray-700">
      <% if (upcomingEvents && upcomingEvents.length > 0) { %>
        <% upcomingEvents.forEach(event => { %>
          <li class="border-b pb-2">
            <strong><%= event.name %></strong><br>
            <em class="text-sm text-gray-500"><%= event.date %></em>
          </li>
        <% }) %>
      <% } else { %>
        <li class="text-center text-gray-500">No upcoming events</li>
      <% } %>
    </ul>
  </div>

  <!-- Contact Info -->
  <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">
      <i class="fas fa-address-card mr-2"></i>Contact Us
    </h2>
    <p class="text-left leading-relaxed text-gray-700">
      <i class="fas fa-map-marker-alt text-secondary mr-2"></i>A1 Road, Opposite Usave<br>
      <span class="ml-5">Behind BEDCO, Butha-Buthe 400</span><br>
      <span class="ml-5">Lesotho</span>
    </p>
    <p class="text-left leading-relaxed text-gray-700 mt-4">
      <i class="fas fa-envelope text-secondary mr-2"></i>tlokza@gmail.com<br>
      <i class="fas fa-phone text-secondary mr-2 mt-2"></i>+266 62233969
    </p>
  </div>

  <!-- Location Map -->
  <div class="bg-white p-8 rounded-xl shadow-lg hover:shadow-2xl transition">
    <h2 class="text-2xl font-bold text-primary mb-4 text-center">
      <i class="fas fa-map mr-2"></i>Our Location
    </h2>
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1485.56110514829!2d28.2472789!3d-28.7689499!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNjZKWCtDNzksIEJ1dGhhLUJ1dGhl!5e0!3m2!1sen!2sls!4v1739637032866!5m2!1sen!2sls"
      class="w-full h-64 rounded-lg border-0"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </div>
</main>

<!-- OUR SERVICES SECTION -->
<section class="bg-gray-100 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-primary">Our Services</h2>
    <div class="grid md:grid-cols-3 gap-10">
      <% routineServices.forEach(service => { %>
        <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transform hover:-translate-y-3 transition duration-300">
          <% if (service.videoLink) { %>
            <iframe class="w-full h-64" src="<%= service.videoLink %>" title="<%= service.name %>" allowfullscreen></iframe>
          <% } else { %>
            <img src="/images/<%= service.image %>" alt="<%= service.name %>" class="w-full h-64 object-cover">
          <% } %>
          <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-primary mb-3"><%= service.name %></h3>
            <% if (!service.videoLink) { %>
              <p class="text-gray-700"><strong>Schedule:</strong> <%= service.schedule %></p>
              <p class="text-gray-700 mt-2"><strong>Contact:</strong> <%= service.contact %></p>
            <% } else { %>
              <p class="text-gray-600 mt-1"><%= service.schedule %></p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
