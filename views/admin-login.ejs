<%- include('partials/header', { activePage: '', title: 'Admin Login' }) %>

<section class="min-h-screen flex items-center justify-center bg-gradient-to-b from-teal-50 to-white py-20">
  <div class="max-w-md w-full px-6">
    <div class="text-center mb-10">
      <img src="/images/logo.webp" alt="RFI Logo" class="h-20 w-auto mx-auto mb-4 rounded-lg">
      <h1 class="text-3xl font-bold text-primary">Admin Access</h1>
      <p class="text-gray-500 mt-2">Revival Fellowship International</p>
    </div>

    <div class="bg-white rounded-2xl shadow-2xl p-10">
      <% if (error) { %>
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
          <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="mb-6">
          <label class="block text-sm font-bold text-gray-700 mb-2">Admin Password</label>
          <input type="password" name="password" required autofocus
                 class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                 placeholder="Enter admin password">
        </div>
        <button type="submit"
                class="w-full bg-primary hover:bg-accent text-white font-bold py-4 rounded-lg transition text-lg">
          <i class="fas fa-lock mr-2"></i>Sign In
        </button>
      </form>

      <div class="mt-6 text-center">
        <a href="/" class="text-sm text-gray-500 hover:text-primary transition">
          &larr; Back to Website
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
