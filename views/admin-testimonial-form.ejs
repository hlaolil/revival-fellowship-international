<%- include('partials/admin-header', { title, currentSection }) %>

<div class="max-w-2xl">
  <a href="/admin/testimonials" class="text-sm text-gray-500 hover:text-primary transition mb-6 inline-block">&larr; Back to Testimonials</a>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
      <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
    </div>
  <% } %>

  <div class="bg-white rounded-2xl shadow-lg p-8">
    <form method="POST" action="<%= testimonial ? '/admin/testimonials/' + testimonial._id + '/update' : '/admin/testimonials/create' %>">

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Full Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" required value="<%= testimonial ? testimonial.name : '' %>"
               placeholder="e.g. Mpho Lekunya"
               class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Role / Description <span class="text-gray-400">(optional)</span></label>
        <input type="text" name="role" value="<%= testimonial ? testimonial.role || '' : '' %>"
               placeholder="e.g. Church Member, Youth Leader"
               class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Testimonial <span class="text-red-500">*</span></label>
        <textarea name="text" required rows="6"
                  placeholder="Write the testimonial here..."
                  class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"><%= testimonial ? testimonial.text : '' %></textarea>
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-accent transition">
          <i class="fas fa-save mr-2"></i><%= testimonial ? 'Save Changes' : 'Add Testimonial' %>
        </button>
        <a href="/admin/testimonials" class="border-2 border-gray-300 text-gray-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/admin-footer') %>
