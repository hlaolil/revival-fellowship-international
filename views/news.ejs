<%- include('partials/header', { activePage: 'news', title: 'News & Announcements', metaDescription: 'Stay up to date with the latest news, announcements, and events from Revival Fellowship International.' }) %>

<section class="hero relative h-72 bg-cover bg-center" style="background-image: url('/images/heroo.webp')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <div class="text-center text-white">
      <h1 class="text-5xl md:text-6xl font-bold font-heading">News &amp; Announcements</h1>
      <p class="mt-4 text-xl text-gray-200">Stay connected with what God is doing at RFI</p>
    </div>
  </div>
</section>

<div class="max-w-7xl mx-auto px-6 py-16">
  <% if (news && news.length > 0) { %>
    <!-- Featured Post -->
    <% const featured = news.find(n => n.featured); %>
    <% if (featured) { %>
      <div class="mb-14">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden md:flex">
          <div class="md:w-1/2">
            <img src="/images/<%= featured.image %>" alt="<%= featured.title %>" class="w-full h-72 md:h-full object-cover">
          </div>
          <div class="md:w-1/2 p-10 flex flex-col justify-center">
            <span class="inline-block bg-secondary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider mb-4 w-fit">Featured</span>
            <span class="text-sm text-gray-500 mb-2"><%= new Date(featured.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
            <h2 class="text-3xl font-bold text-primary mb-4"><%= featured.title %></h2>
            <p class="text-gray-600 leading-relaxed mb-6"><%= featured.excerpt %></p>
            <a href="/news/<%= featured.slug %>" class="inline-block bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-accent transition w-fit">
              Read More &rarr;
            </a>
          </div>
        </div>
      </div>
    <% } %>

    <!-- All Posts Grid -->
    <h2 class="text-2xl font-bold text-primary mb-8">All Articles</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% news.forEach(post => { %>
        <article class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition transform hover:-translate-y-2 flex flex-col">
          <img src="/images/<%= post.image %>" alt="<%= post.title %>" class="w-full h-48 object-cover">
          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-center gap-3 mb-3">
              <span class="bg-primary/10 text-primary text-xs font-bold px-3 py-1 rounded-full"><%= post.category %></span>
              <span class="text-xs text-gray-400"><%= new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-3"><%= post.title %></h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-1"><%= post.excerpt %></p>
            <a href="/news/<%= post.slug %>" class="mt-5 inline-block text-primary font-semibold hover:underline text-sm">
              Read More &rarr;
            </a>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-20">
      <i class="fas fa-newspaper text-6xl text-gray-300 mb-6"></i>
      <p class="text-2xl text-gray-500">No articles yet. Check back soon!</p>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
