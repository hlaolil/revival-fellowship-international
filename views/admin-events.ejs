<%- include('partials/admin-header', { title, currentSection }) %>

<div class="flex justify-between items-center mb-8">
  <p class="text-gray-500"><%= events.length %> event<%= events.length !== 1 ? 's' : '' %> total</p>
  <a href="/admin/events/new" class="bg-primary text-white px-5 py-2 rounded-full font-semibold hover:bg-accent transition">
    <i class="fas fa-plus mr-2"></i>Add Event
  </a>
</div>

<div class="bg-white rounded-2xl shadow-lg overflow-hidden">
  <% if (events.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-100">
          <tr>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Event Name</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Date</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Category</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Time</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% events.forEach((e, i) => { %>
            <tr class="border-t <%= i % 2 === 0 ? 'bg-white' : 'bg-gray-50' %>">
              <td class="px-4 py-3 font-semibold"><%= e.name %></td>
              <td class="px-4 py-3 text-gray-600"><%= e.date %></td>
              <td class="px-4 py-3"><span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded-full capitalize"><%= e.category || '—' %></span></td>
              <td class="px-4 py-3 text-gray-500"><%= e.time || '—' %></td>
              <td class="px-4 py-3 flex gap-2">
                <a href="/admin/events/<%= e._id %>/edit" class="bg-secondary text-white px-3 py-1 rounded-full text-xs font-semibold hover:bg-orange-600 transition">
                  <i class="fas fa-edit mr-1"></i>Edit
                </a>
                <form method="POST" action="/admin/events/<%= e._id %>/delete" onsubmit="return confirm('Delete this event?')">
                  <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded-full text-xs font-semibold hover:bg-red-700 transition">
                    <i class="fas fa-trash mr-1"></i>Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="p-16 text-center text-gray-400">
      <i class="fas fa-calendar-alt text-5xl mb-4"></i>
      <p class="text-lg mb-4">No events yet.</p>
      <a href="/admin/events/new" class="bg-primary text-white px-6 py-2 rounded-full font-semibold hover:bg-accent transition">Add First Event</a>
    </div>
  <% } %>
</div>

<%- include('partials/admin-footer') %>
