<%- include('partials/header', { activePage: 'join' }) %>

<section class="py-20 bg-gradient-to-b from-teal-50 to-white">
  <div class="max-w-3xl mx-auto text-center px-6">
    <i class="fas fa-check-circle text-9xl text-primary mb-8"></i>
    <h1 class="text-5xl font-bold text-primary mb-6">Thank You!</h1>
    <p class="text-xl mb-8">We appreciate your interest in Revival Fellowship International.</p>

    <div class="bg-white p-8 rounded-2xl shadow-2xl">
      <h2 class="text-3xl font-bold text-primary mb-8">Your Submission Details</h2>

      <div class="text-left space-y-4 text-lg">
        <p><strong>First Name:</strong> <%= firstName %></p>
        <p><strong>Last Name:</strong> <%= lastName %></p>
        <p><strong>Email:</strong> <%= email %></p>
        <p><strong>Phone:</strong> <%= phone %></p>
        <p><strong>Enquiry Type:</strong> <%= enquiryType.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()) %></p>
        <p><strong>Message:</strong> <%= message || 'No message provided' %></p>
        <p><strong>Submitted on:</strong> <%= timestamp %></p>
      </div>

      <div class="mt-10 text-center">
        <a href="/" class="bg-primary hover:bg-accent text-white font-bold py-4 px-10 rounded-full text-xl">Go Home</a>
        <a href="/join" class="ml-4 bg-secondary hover:bg-orange-600 text-white font-bold py-4 px-10 rounded-full text-xl">Back to Form</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
