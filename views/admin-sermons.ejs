<%- include('partials/admin-header', { title, currentSection }) %>

<div class="flex justify-between items-center mb-8">
  <p class="text-gray-500"><%= sermons.length %> sermon<%= sermons.length !== 1 ? 's' : '' %> total</p>
  <a href="/admin/sermons/new" class="bg-primary text-white px-5 py-2 rounded-full font-semibold hover:bg-accent transition">
    <i class="fas fa-plus mr-2"></i>Add Sermon
  </a>
</div>

<div class="grid md:grid-cols-2 gap-6">
  <% if (sermons.length > 0) { %>
    <% sermons.forEach(s => { %>
      <div class="bg-white rounded-2xl shadow overflow-hidden flex">
        <img src="https://img.youtube.com/vi/<%= s.videoId %>/default.jpg"
             alt="<%= s.title %>"
             class="w-24 h-24 object-cover flex-shrink-0 self-stretch">
        <div class="p-4 flex flex-col flex-1 min-w-0">
          <p class="font-bold text-gray-800 truncate"><%= s.title %></p>
          <p class="text-xs text-gray-400 mt-1">
            <i class="fas fa-calendar mr-1"></i><%= s.date %>
            &bull; <i class="fas fa-book-open mr-1"></i><%= s.series || 'No series' %>
          </p>
          <p class="text-xs text-gray-500 mt-1 truncate"><i class="fab fa-youtube text-red-500 mr-1"></i><%= s.videoId %></p>
          <% if (s.featured) { %>
            <span class="mt-1 inline-block bg-secondary text-white text-xs font-bold px-2 py-0.5 rounded-full w-fit">Featured</span>
          <% } %>
          <div class="flex gap-2 mt-3">
            <a href="/admin/sermons/<%= s._id %>/edit" class="bg-secondary text-white px-3 py-1 rounded-full text-xs font-semibold hover:bg-orange-600 transition">
              <i class="fas fa-edit mr-1"></i>Edit
            </a>
            <form method="POST" action="/admin/sermons/<%= s._id %>/delete" onsubmit="return confirm('Delete this sermon?')">
              <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded-full text-xs font-semibold hover:bg-red-700 transition">
                <i class="fas fa-trash mr-1"></i>Delete
              </button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="col-span-2 bg-white rounded-2xl shadow p-16 text-center text-gray-400">
      <i class="fas fa-video text-5xl mb-4"></i>
      <p class="text-lg mb-4">No sermons yet.</p>
      <a href="/admin/sermons/new" class="bg-primary text-white px-6 py-2 rounded-full font-semibold hover:bg-accent transition">Add First Sermon</a>
    </div>
  <% } %>
</div>

<%- include('partials/admin-footer') %>
