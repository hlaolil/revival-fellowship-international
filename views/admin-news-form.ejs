<%- include('partials/admin-header', { title, currentSection }) %>

<div class="max-w-3xl">
  <a href="/admin/news" class="text-sm text-gray-500 hover:text-primary transition mb-6 inline-block">&larr; Back to News</a>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
      <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
    </div>
  <% } %>

  <div class="bg-white rounded-2xl shadow-lg p-8">
    <form method="POST" action="<%= article ? '/admin/news/' + article._id + '/update' : '/admin/news/create' %>">

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Title <span class="text-red-500">*</span></label>
        <input type="text" name="title" required value="<%= article ? article.title : '' %>"
               placeholder="Article headline"
               class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        <p class="text-xs text-gray-400 mt-1">A URL slug will be auto-generated from the title.</p>
      </div>

      <div class="grid grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Date</label>
          <input type="date" name="date" value="<%= article ? article.date : new Date().toISOString().split('T')[0] %>"
                 class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Author</label>
          <input type="text" name="author" value="<%= article ? article.author : 'RFI Leadership' %>"
                 class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        </div>
      </div>

      <div class="grid grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Category</label>
          <input type="text" name="category" value="<%= article ? article.category : 'Announcement' %>"
                 placeholder="e.g. Announcement, Special Event, Training"
                 class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Cover Image Filename</label>
          <input type="text" name="image" value="<%= article ? article.image : 'service.jpg' %>"
                 placeholder="e.g. service.jpg, prayer.jpg"
                 class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Excerpt <span class="text-gray-400">(short summary)</span></label>
        <textarea name="excerpt" rows="3"
                  placeholder="A short summary shown on the news list page..."
                  class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"><%= article ? article.excerpt : '' %></textarea>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Full Content <span class="text-red-500">*</span></label>
        <textarea name="content" required rows="12"
                  placeholder="Write the full article here. Separate paragraphs with a blank line."
                  class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent font-mono text-sm"><%= article ? article.content : '' %></textarea>
        <p class="text-xs text-gray-400 mt-1">Separate paragraphs with a blank line. Each paragraph will be displayed on its own line.</p>
      </div>

      <div class="mb-8">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" name="featured" value="on" <%= article && article.featured ? 'checked' : '' %>
                 class="w-5 h-5 rounded text-primary focus:ring-primary">
          <span class="font-semibold text-gray-700">Mark as Featured Article</span>
        </label>
        <p class="text-xs text-gray-400 mt-1 ml-8">Featured articles appear prominently at the top of the news page.</p>
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-accent transition">
          <i class="fas fa-save mr-2"></i><%= article ? 'Save Changes' : 'Publish Article' %>
        </button>
        <a href="/admin/news" class="border-2 border-gray-300 text-gray-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/admin-footer') %>
