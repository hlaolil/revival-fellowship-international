<%- include('partials/admin-header', { title, currentSection }) %>

<!-- Stats -->
<div class="grid grid-cols-2 md:grid-cols-5 gap-5 mb-10">
  <% const stats = [
    { label: 'Submissions', value: submissions.length, icon: 'fa-inbox', color: 'text-primary' },
    { label: 'Events',      value: eventsCount,        icon: 'fa-calendar-alt', color: 'text-secondary' },
    { label: 'News',        value: newsCount,          icon: 'fa-newspaper', color: 'text-primary' },
    { label: 'Testimonials',value: testimonialsCount,  icon: 'fa-quote-right', color: 'text-secondary' },
    { label: 'Sermons',     value: sermonsCount,       icon: 'fa-video', color: 'text-primary' },
  ]; %>
  <% stats.forEach(s => { %>
    <div class="bg-white rounded-xl shadow p-5 text-center">
      <i class="fas <%= s.icon %> text-2xl <%= s.color %> mb-2"></i>
      <p class="text-3xl font-bold <%= s.color %>"><%= s.value %></p>
      <p class="text-gray-500 text-xs mt-1 font-semibold"><%= s.label %></p>
    </div>
  <% }) %>
</div>

<!-- Manage Content shortcuts -->
<div class="grid md:grid-cols-4 gap-4 mb-10">
  <a href="/admin/events" class="bg-white border-2 border-primary text-primary rounded-xl p-5 hover:bg-primary hover:text-white transition flex items-center gap-3 font-semibold">
    <i class="fas fa-calendar-alt text-xl"></i>Manage Events
  </a>
  <a href="/admin/testimonials" class="bg-white border-2 border-secondary text-secondary rounded-xl p-5 hover:bg-secondary hover:text-white transition flex items-center gap-3 font-semibold">
    <i class="fas fa-quote-right text-xl"></i>Manage Testimonials
  </a>
  <a href="/admin/news" class="bg-white border-2 border-primary text-primary rounded-xl p-5 hover:bg-primary hover:text-white transition flex items-center gap-3 font-semibold">
    <i class="fas fa-newspaper text-xl"></i>Manage News
  </a>
  <a href="/admin/sermons" class="bg-white border-2 border-secondary text-secondary rounded-xl p-5 hover:bg-secondary hover:text-white transition flex items-center gap-3 font-semibold">
    <i class="fas fa-video text-xl"></i>Manage Sermons
  </a>
</div>

<!-- Submissions table -->
<div class="bg-white rounded-2xl shadow-lg overflow-hidden">
  <div class="px-6 py-4 border-b bg-gray-50">
    <h2 class="text-lg font-bold text-primary"><i class="fas fa-inbox mr-2"></i>Form Submissions (Latest 50)</h2>
  </div>
  <% if (dbError) { %>
    <div class="p-6 bg-yellow-50 text-yellow-700 border-b text-sm"><i class="fas fa-exclamation-triangle mr-2"></i><%= dbError %></div>
  <% } %>
  <% if (submissions && submissions.length > 0) { %>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-100">
          <tr>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Name</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Email</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Phone</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Type</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Message</th>
            <th class="px-4 py-3 text-left font-bold text-gray-600">Date</th>
          </tr>
        </thead>
        <tbody>
          <% submissions.forEach((s, i) => { %>
            <tr class="border-t <%= i % 2 === 0 ? 'bg-white' : 'bg-gray-50' %>">
              <td class="px-4 py-3 font-semibold"><%= s.firstName %> <%= s.lastName %></td>
              <td class="px-4 py-3"><a href="mailto:<%= s.email %>" class="text-primary hover:underline"><%= s.email %></a></td>
              <td class="px-4 py-3"><%= s.phone %></td>
              <td class="px-4 py-3"><span class="bg-primary/10 text-primary px-2 py-1 rounded-full text-xs font-bold"><%= s.enquiryType ? s.enquiryType.replace(/-/g,' ').replace(/\b\w/g,l=>l.toUpperCase()) : 'Unknown' %></span></td>
              <td class="px-4 py-3 text-gray-600 max-w-xs truncate"><%= s.message || '—' %></td>
              <td class="px-4 py-3 text-gray-400 text-xs"><%= s.submittedAt ? new Date(s.submittedAt).toLocaleString() : s.timestamp %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else if (!dbError) { %>
    <div class="p-10 text-center text-gray-400"><i class="fas fa-inbox text-5xl mb-4"></i><p class="text-lg">No submissions yet.</p></div>
  <% } %>
</div>

<%- include('partials/admin-footer') %>
