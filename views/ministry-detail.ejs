<%- include('partials/header', { activePage: 'ministries', title: ministry.name, metaDescription: ministry.description || 'Learn about ' + ministry.name + ' at Revival Fellowship International.' }) %>

<section class="hero relative h-96 bg-cover bg-center" style="background-image: url('/images/<%= ministry.resolvedImage || "heroo.webp" %>')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <div class="text-center text-white px-4">
      <p class="text-secondary font-semibold text-lg mb-2 uppercase tracking-wider">Ministry</p>
      <h1 class="text-5xl md:text-6xl font-bold font-heading"><%= ministry.name %></h1>
    </div>
  </div>
</section>

<div class="max-w-5xl mx-auto px-6 py-16">
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-10">
    <a href="/" class="hover:text-primary transition">Home</a>
    <span class="mx-2">/</span>
    <a href="/ministries" class="hover:text-primary transition">Ministries</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700 font-semibold"><%= ministry.name %></span>
  </nav>

  <div class="grid md:grid-cols-3 gap-12">
    <!-- Main Content -->
    <div class="md:col-span-2">
      <h2 class="text-3xl font-bold text-primary mb-6">About <%= ministry.name %></h2>
      <p class="text-gray-700 text-xl leading-relaxed mb-8"><%= ministry.description %></p>

      <div class="bg-gradient-to-br from-primary/5 to-secondary/5 rounded-2xl p-8 space-y-4">
        <h3 class="text-xl font-bold text-primary mb-4">Ministry Details</h3>
        <div class="flex items-center gap-4 text-gray-700">
          <i class="fas fa-clock text-secondary text-xl w-6"></i>
          <div>
            <p class="font-semibold">Meeting Schedule</p>
            <p><%= ministry.schedule %></p>
          </div>
        </div>
        <div class="flex items-center gap-4 text-gray-700">
          <i class="fas fa-phone text-secondary text-xl w-6"></i>
          <div>
            <p class="font-semibold">Contact</p>
            <p><%= ministry.contact %></p>
          </div>
        </div>
        <div class="flex items-center gap-4 text-gray-700">
          <i class="fas fa-map-marker-alt text-secondary text-xl w-6"></i>
          <div>
            <p class="font-semibold">Location</p>
            <p>A1 Road, Butha-Buthe 400, Lesotho</p>
          </div>
        </div>
      </div>

      <div class="mt-10 flex flex-wrap gap-4">
        <a href="/inquire?type=information-request" class="bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-accent transition">
          <i class="fas fa-envelope mr-2"></i>Get In Touch
        </a>
        <a href="https://wa.me/26662233969" target="_blank" class="bg-green-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-green-600 transition">
          <i class="fab fa-whatsapp mr-2"></i>WhatsApp Us
        </a>
      </div>
    </div>

    <!-- Sidebar -->
    <div>
      <% if (ministry.resolvedImage) { %>
        <img src="/images/<%= ministry.resolvedImage %>" alt="<%= ministry.name %>" class="w-full rounded-2xl shadow-lg mb-6 object-cover h-64">
      <% } %>

      <div class="bg-white rounded-2xl shadow-lg p-6">
        <h3 class="text-lg font-bold text-primary mb-4">Other Ministries</h3>
        <ul class="space-y-3">
          <% others.forEach(other => { %>
            <li>
              <a href="/ministries/<%= other.slug %>" class="flex items-center gap-3 text-gray-700 hover:text-primary transition group">
                <% if (other.resolvedImage) { %>
                  <img src="/images/<%= other.resolvedImage %>" alt="<%= other.name %>" class="w-10 h-10 rounded-lg object-cover flex-shrink-0">
                <% } else { %>
                  <div class="w-10 h-10 bg-gray-200 rounded-lg flex items-center justify-center flex-shrink-0">
                    <i class="fas fa-church text-gray-400"></i>
                  </div>
                <% } %>
                <span class="font-semibold group-hover:underline"><%= other.name %></span>
              </a>
            </li>
          <% }) %>
        </ul>
        <div class="mt-5 pt-5 border-t">
          <a href="/ministries" class="text-primary font-semibold hover:underline text-sm">
            &larr; All Ministries
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
