<%- include('partials/admin-header', { title, currentSection }) %>

<div class="max-w-2xl">
  <a href="/admin/events" class="text-sm text-gray-500 hover:text-primary transition mb-6 inline-block">&larr; Back to Events</a>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 mb-6 text-sm">
      <i class="fas fa-exclamation-circle mr-2"></i><%= error %>
    </div>
  <% } %>

  <div class="bg-white rounded-2xl shadow-lg p-8">
    <form method="POST" action="<%= event ? '/admin/events/' + event._id + '/update' : '/admin/events/create' %>">

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Event Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" required value="<%= event ? event.name : '' %>"
               placeholder="e.g. Fasting Sunday"
               class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
      </div>

      <div class="mb-6">
        <label class="block text-sm font-bold text-gray-700 mb-2">Date <span class="text-red-500">*</span></label>
        <input type="text" name="date" required value="<%= event ? event.date : '' %>"
               placeholder="YYYY-MM-DD for specific dates, or 'Every Sunday', 'Ad hoc', etc."
               class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        <p class="text-xs text-gray-400 mt-1">Use YYYY-MM-DD for specific dates (e.g. 2026-12-04). For recurring events use plain text (e.g. "Every Sunday").</p>
      </div>

      <div class="grid grid-cols-2 gap-6 mb-6">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Category</label>
          <select name="category" class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary">
            <% const cats = ['routine','prayer','fast','training','special','outreach']; %>
            <% cats.forEach(c => { %>
              <option value="<%= c %>" <%= event && event.category === c ? 'selected' : '' %>><%= c.charAt(0).toUpperCase() + c.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Time <span class="text-gray-400">(optional)</span></label>
          <input type="text" name="time" value="<%= event ? event.time || '' : '' %>"
                 placeholder="e.g. 10:00 - 13:00"
                 class="w-full p-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
        </div>
      </div>

      <div class="flex gap-4">
        <button type="submit" class="bg-primary text-white px-8 py-3 rounded-full font-semibold hover:bg-accent transition">
          <i class="fas fa-save mr-2"></i><%= event ? 'Save Changes' : 'Create Event' %>
        </button>
        <a href="/admin/events" class="border-2 border-gray-300 text-gray-600 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/admin-footer') %>
