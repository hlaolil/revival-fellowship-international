<%- include('partials/header', { activePage: 'ministries', title: 'Ministries' }) %>

<section class="hero relative h-96 bg-cover bg-center" style="background-image: url('/images/heroo.webp')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <h1 class="text-5xl md:text-7xl font-bold text-white font-heading">Our Ministries</h1>
  </div>
</section>

<div class="max-w-7xl mx-auto px-6 py-16">
  <% if (ministries && ministries.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
      <% ministries.forEach(ministry => { %>
        <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transition transform hover:-translate-y-4 flex flex-col">
          <% if (ministry.resolvedImage) { %>
            <img
              src="/images/<%= ministry.resolvedImage %>"
              alt="<%= ministry.name %>"
              class="w-full h-48 object-cover"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            >
            <div class="bg-gray-200 h-48 items-center justify-center text-gray-500 hidden">No Image</div>
          <% } else { %>
            <div class="bg-gray-200 h-48 flex items-center justify-center text-gray-500">No Image</div>
          <% } %>
          <div class="p-6 flex flex-col flex-1">
            <h2 class="text-2xl font-bold text-primary mb-3 text-center"><%= ministry.name %></h2>
            <% if (ministry.description) { %>
              <p class="text-gray-600 text-center text-sm mb-4 flex-1"><%= ministry.description %></p>
            <% } %>
            <div class="border-t pt-4 mt-auto space-y-2 text-sm text-center text-gray-700">
              <p><i class="fas fa-clock text-secondary mr-1"></i><strong>Schedule:</strong> <%= ministry.schedule %></p>
              <p><i class="fas fa-phone text-secondary mr-1"></i><strong>Contact:</strong> <%= ministry.contact %></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-center text-2xl text-gray-600 py-20">No ministries listed yet. Check back soon!</p>
  <% } %>
</div>

<%- include('partials/footer') %>
