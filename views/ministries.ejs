<%- include('partials/header', { activePage: 'ministries' }) %>

<section class="hero relative h-96 bg-cover bg-center" style="background-image: url('/images/heroo.webp')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <h1 class="text-5xl md:text-7xl font-bold text-white font-heading">Our Ministries</h1>
  </div>
</section>

<div class="max-w-7xl mx-auto px-6 py-16">
  <% if (ministries && ministries.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
      <% ministries.forEach(ministry => { %>
        <% 
          let webImageUrl = '';
          const nameLower = ministry.name.toLowerCase();

          // Youth Meeting
          if (nameLower.includes('youth')) {
            webImageUrl = 'https://www.newcovenantgj.org/wp-content/uploads/2016/05/youthgroup-1.png';
          }
          // Children's Ministry
          else if (nameLower.includes('children')) {
            webImageUrl = 'https://dq5pwpg1q8ru0.cloudfront.net/2023/09/26/10/00/33/a7034417-25bd-449f-8aff-2270c8a8575e/istockphoto-1205606503-612x612.jpg';
          }
          // Men’s Fellowship
          else if (nameLower.includes('men')) {
            webImageUrl = 'https://www.resourceumc.org/-/media/umc-media/2019/05/06/18/11/mens-bible-study-group-lightstock_31971-shaun-menaryjpg.jpg';
          }
          // Women’s Meeting – NEW: Beautiful group of Black women in joyful worship/prayer
          else if (nameLower.includes('women')) {
            webImageUrl = 'https://www.umnews.org/-/media/umc-media/2025/10/24/21/54/women-of-substance-1-mountain-prayer-praise-1200x800px.jpg';
          }
        %>

        <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transition transform hover:-translate-y-4">
          <% if (webImageUrl) { %>
            <img src="<%= webImageUrl %>?v=<%= Date.now() %>" alt="<%= ministry.name %>" class="w-full h-48 object-cover">
          <% } else if (ministry.image) { %>
            <img src="/images/<%= ministry.image %>" alt="<%= ministry.name %>" class="w-full h-48 object-cover">
          <% } else { %>
            <div class="bg-gray-200 h-48 flex items-center justify-center text-gray-500">No Image</div>
          <% } %>

          <div class="p-6">
            <h2 class="text-2xl font-bold text-primary mb-4 text-center"><%= ministry.name %></h2>
            <p class="text-center"><strong>Schedule:</strong> <%= ministry.schedule %></p>
            <p class="text-center mt-4"><strong>Contact:</strong> <%= ministry.contact %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-center text-2xl text-gray-600 py-20">No ministries listed yet. Check back soon!</p>
  <% } %>
</div>

<%- include('partials/footer') %>
