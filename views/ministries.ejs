<%- include('partials/header', { activePage: 'ministries' }) %>
<section class="hero relative h-96 bg-cover bg-center" style="background-image: url('/images/heroo.webp')">
  <div class="absolute inset-0 bg-black bg-opacity-60 flex items-center justify-center">
    <h1 class="text-5xl md:text-7xl font-bold text-white font-heading">Our Ministries</h1>
  </div>
</section>

<div class="max-w-7xl mx-auto px-6 py-16">
  <% if (ministries && ministries.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10">
      <% ministries.forEach(ministry => { %>
        <%
          let name = ministry.name.toLowerCase();
          let webImageUrl = '';

          // Worship Ministry
          if (name.includes('worship')) {
            webImageUrl = 'https://thechurchcollective.com/wp-content/uploads/2020/02/handsupteam-800x600.jpg';

          // Youth Ministry
          } else if (name.includes('youth')) {
            webImageUrl = 'https://www.newcovenantgj.org/wp-content/uploads/2016/05/youthgroup-1.png';

          // Children Ministry
          } else if (name.includes('children') || name.includes('sunday school') || name.includes('kids')) {
            webImageUrl = 'https://dq5pwpg1q8ru0.cloudfront.net/2023/09/26/10/00/33/a7034417-25bd-449f-8aff-2270c8a8575e/istockphoto-1205606503-612x612.jpg';

          // Prayer Ministry
          } else if (name.includes('prayer')) {
            webImageUrl = 'https://images.squarespace-cdn.com/content/v1/64e47261734e15442f306693/1724797432570-3P4IQECSWIYY63R3Q833/Prayer+Meeting+copy.jpg';

          // Outreach Ministry
          } else if (name.includes('outreach') || name.includes('community') || name.includes('service')) {
            webImageUrl = 'https://www.churchtrac.com/articles/images/blog_church_outreach_programs_ideas_feature.jpg';

          // Bible Study
          } else if (name.includes('bible') || name.includes('study')) {
            webImageUrl = 'https://media.swncdn.com/cms/CW/faith/47910-church-fellowship-1200.1200w.tn.jpg';

          // Choir / Music
          } else if (name.includes('choir') || name.includes('music')) {
            webImageUrl = 'https://images.squarespace-cdn.com/content/v1/597128506f4ca3125f8bdf84/1520466386197-SGFQ3IRMLA2OH5E2LJNO/Choir.jpg';

          // -------- WOMEN'S MINISTRY --------
          } else if (
            name.includes('women’s') ||
            name.includes("women's") ||
            name.includes('womens') ||
            name.includes('women') ||
            name.includes('lady') ||
            name.includes('ladies') ||
            name.includes('woman')
          ) {
            webImageUrl = 'https://images.unsplash.com/photo-1594737625776-241e9d4ea2c6?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80';

          // -------- MEN'S MINISTRY - NOW SHOWS BLACK MEN --------
          } else if (name.includes('men')) {
            webImageUrl = 'https://images.unsplash.com/photo-1582213782179-1d3e6ac5c77c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80';
            // Black Christian men praying together with Bibles – powerful, dignified, and widely used on church sites
          }
        %>

        <div class="bg-white rounded-xl overflow-hidden shadow-xl hover:shadow-2xl transition transform hover:-translate-y-4">
          <img
            src="<%= webImageUrl ? webImageUrl : (ministry.image ? '/images/' + ministry.image : '') %>"
            alt="<%= ministry.name %>"
            class="w-full h-48 object-cover <%= !webImageUrl && !ministry.image ? 'hidden' : '' %>"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          >
          <div class="bg-gray-200 h-48 flex items-center justify-center text-gray-500 <%= webImageUrl || ministry.image ? 'hidden' : '' %>">
            No Image
          </div>
          <div class="p-6">
            <h2 class="text-2xl font-bold text-primary mb-4 text-center"><%= ministry.name %></h2>
            <p class="text-center"><strong>Schedule:</strong> <%= ministry.schedule %></p>
            <p class="text-center mt-4"><strong>Contact:</strong> <%= ministry.contact %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-center text-2xl text-gray-600 py-20">No ministries listed yet. Check back soon!</p>
  <% } %>
</div>

<%- include('partials/footer') %>
